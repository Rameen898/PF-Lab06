#include <stdio.h>

int main()
{
    int i, status, total = 0;

    for(i = 1; i <= 25; i++)
    {
        printf("Enter status for member %d (1 or 0): ", i);
        scanf("%d", &status);

        if(status == 1)
        {
            total++;
        }
    }

    printf("Total members checked in: %d\n", total);

    return 0;
}
